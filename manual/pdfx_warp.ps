%!
% OutputIntent definition file for the WARP print manuals.

/ICCProfile (color/ISOcoated_v2_300_eci.icc) def

[ /Title (WARP Charger Betriebsanleitung)
  /DOCINFO pdfmark

[ /_objdef {icc_PDFX} /type /stream /OBJ pdfmark
[ {icc_PDFX} <</N 4>> /PUT pdfmark
[ {icc_PDFX} ICCProfile (r) file /PUT pdfmark

[ /_objdef {OutputIntent_PDFX} /type /dict /OBJ pdfmark
[ {OutputIntent_PDFX} <<
    /Type /OutputIntent
    /S /GTS_PDFX
    /OutputCondition (ISO Coated v2 300% \050ECI\051)
    /OutputConditionIdentifier (FOGRA39)
    /RegistryName (http://www.color.org)
    /Info (ISO Coated v2 300% \050ECI\051, ISO 12647-2:2004 / FOGRA39)
    /DestOutputProfile {icc_PDFX}
  >> /PUT pdfmark

[ {Catalog} <</OutputIntents [ {OutputIntent_PDFX} ]>> /PUT pdfmark
